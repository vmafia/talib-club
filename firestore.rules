rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["staff", "admin", "owner"];
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "owner"];
    }

    function isOwner() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "owner";
    }

    function isOwnerOrAdmin() {
      return isAdmin();
    }

    function isSignedInUser(uid) {
      return signedIn() && uid == request.auth.uid;
    }

    function ownsExistingDocument() {
      return signedIn() && resource.data.uid == request.auth.uid;
    }

    function keepsOwnership() {
      return request.resource.data.uid == request.auth.uid;
    }

    // --- Users Collection Rules ---
    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isStaff());
      allow create: if signedIn() 
        && request.auth.uid == userId
        && (!("role" in request.resource.data) || request.resource.data.role == "member");
      allow update: if isOwnerOrAdmin()
        || (signedIn()
          && request.auth.uid == userId
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])));
      allow delete: if isOwner();
    }

    // --- System Analytics Collections ---
    match /site_visits/{docId} {
      allow read: if isStaff();
      allow create: if true;
    }

    // --- Public Content Collections ---
    match /content_articles/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /content_books/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /content_media/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /content_scholars/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /content_settings/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // --- User-Specific Content Collections ---
    match /content_bookmarks/{docId} {
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if ownsExistingDocument() && keepsOwnership();
      allow delete: if ownsExistingDocument();
    }

    match /content_bookshelf/{docId} {
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if ownsExistingDocument() && keepsOwnership();
      allow delete: if ownsExistingDocument();
    }

    match /content_reading_sessions/{docId} {
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if ownsExistingDocument() && keepsOwnership();
      allow delete: if ownsExistingDocument();
    }

    match /content_reading_streaks/{docId} {
      allow read: if signedIn() && (docId == request.auth.uid || isStaff());
      allow create, update: if signedIn() && docId == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && docId == request.auth.uid;
    }

    match /content_quran_bookmarks/{docId} {
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if ownsExistingDocument() && keepsOwnership();
      allow delete: if ownsExistingDocument();
    }

    match /content_quran_last_read/{docId} {
      allow read: if signedIn() && (docId == request.auth.uid + "_last_read" || isStaff());
      allow create, update: if signedIn() && docId == request.auth.uid + "_last_read" && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && docId == request.auth.uid + "_last_read";
    }

    match /content_history/{docId} {
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if ownsExistingDocument() && keepsOwnership();
      allow delete: if ownsExistingDocument();
    }

    // --- Push Notification Subscriptions (C3: was missing) ---
    match /push_subscriptions/{docId} {
      allow read: if isStaff();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(["subscription", "endpoint", "uid", "userId", "isStaff", "updatedAt"]);
      allow update: if ownsExistingDocument() && keepsOwnership();
      allow delete: if ownsExistingDocument();
    }

    // --- Staff Portal Collections ---
    match /system/{docId} {
      allow read, write: if isStaff();
    }

    match /counters/{docId} {
      allow read, write: if isStaff();
    }

    match /submissions/{docId} {
      allow read, write: if isStaff();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /translation_abuiyaad/{docId} {
      allow read, write: if isStaff();
    }

    // --- Logistics Tracking Collections ---
    match /records/{docId} {
      allow get: if isStaff();
      allow list: if isStaff() || (signedIn() && request.query.limit != null && request.query.limit <= 5);
      allow write: if isStaff();
    }

    match /recipients/{docId} {
      allow get: if isStaff();
      allow list: if isStaff() || (signedIn() && request.query.limit != null && request.query.limit <= 5);
      allow write: if isStaff();
    }

    match /staff_tasks/{docId} {
      allow read, write: if isStaff();
    }

    match /content_calendar/{docId} {
      allow read, write: if isStaff();
    }

    match /openhouse_booths/{document=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /book_campaigns/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /book_campaigns/{campaignId}/holds/{holdId} {
      allow read, write: if isStaff();
    }

    match /book_registrations/{docId} {
      allow create: if isStaff();
      allow get: if signedIn() && (resource.data.uid == request.auth.uid || isStaff());
      allow list: if isStaff();
      allow update: if isStaff();
      allow delete: if isStaff();
    }
  }
}
