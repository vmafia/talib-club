rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return signedIn()
        && (request.auth.token.email == "islamofwhite@gmail.com" ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "staff" ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    function isAdmin() {
      return signedIn()
        && (request.auth.token.email == "islamofwhite@gmail.com" ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    function isOwner() {
      return signedIn()
        && request.auth.token.email == "islamofwhite@gmail.com";
    }

    function isOwnerOrAdmin() {
      return isOwner() || isAdmin();
    }

    // --- Users Collection Rules ---
    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isStaff());
      allow create: if signedIn() 
        && request.auth.uid == userId
        && (!("role" in request.resource.data) || request.resource.data.role == "member");
      allow update: if isOwnerOrAdmin()
        || (signedIn()
          && request.auth.uid == userId
          && (!("role" in request.resource.data) || request.resource.data.role == resource.data.role));
      allow delete: if isOwner();
    }

    // --- Public Content Collections ---
    match /content_articles/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /content_books/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /content_media/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /content_scholars/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /content_settings/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // --- User-Specific Content Collections ---
    match /content_bookmarks/{docId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /content_bookshelf/{docId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /content_reading_sessions/{docId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /content_reading_streaks/{docId} {
      allow read: if signedIn() && docId == request.auth.uid;
      allow create, update: if signedIn() && docId == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && docId == request.auth.uid;
    }

    match /content_quran_bookmarks/{docId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /content_quran_last_read/{docId} {
      allow read: if signedIn() && docId == request.auth.uid + "_last_read";
      allow create, update: if signedIn() && docId == request.auth.uid + "_last_read" && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && docId == request.auth.uid + "_last_read";
    }

    match /content_history/{docId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // --- Staff Portal Collections ---
    match /submissions/{docId} {
      allow read, write: if isStaff();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /translation_abuiyaad/{docId} {
      allow read, write: if isStaff();
    }

    // --- Logistics Tracking Collections ---
    match /records/{docId} {
      allow get: if true;
      allow list: if isStaff() || (request.query.limit != null && request.query.limit <= 5 && request.query.filters.size() > 0);
      allow write: if isStaff();
    }

    match /recipients/{docId} {
      allow get: if true;
      allow list: if isStaff() || (request.query.limit != null && request.query.limit <= 5 && request.query.filters.size() > 0);
      allow write: if isStaff();
    }
  }
}
